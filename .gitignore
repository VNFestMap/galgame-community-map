# 备份文件
*.bak

# Python 临时文件
*.pyc
*.pyo
__pycache__/

# 编辑器配置
.vscode/
.idea/
*.swp

# 系统文件
.DS_Store
Thumbs.db

# 原始数据（CSV/Excel，不上传）
*.csv
*.xlsx
副本-*.csv
副本-*.xlsx

# 临时脚本
convert_*.py
update_*.py
excel_*.py
deepseek_*.py

# 敏感配置文件
config.php
.env
.env.local
.env.*.local

# 不要忽略模板文件
!config.example.php
!.env.example

# 数据库文件（包含生产数据）
data/*.sql
data/*.db
data/*.sqlite

# 用户上传文件
data/avatars/*
!data/avatars/.gitkeep
data/club_avatars/*
!data/club_avatars/.gitkeep
data/publication_images/*
!data/publication_images/.gitkeep

# 提交数据（含用户提交的个人信息）
data/submissions*.json
data/qq_members.json

# 服务器配置（暴露目录路径）
.user.ini

# 其他敏感
*.key
*.pem
.secrets/